      "allowedRoles": ["deployadmin"]
    },
    {
      "route": "/api/AddWinGetApp",
      "allowedRoles": ["deployadmin"]
    },
    {
      "route": "/api/AddOfficeApp",
      "allowedRoles": ["deployadmin"]
    },
    {
      "route": "/api/AddMSPApp",
      "allowedRoles": ["deployadmin"]
    },   
    {
      "route": "/api/AddAutopilotConfig",
      "allowedRoles": ["deployadmin"]
