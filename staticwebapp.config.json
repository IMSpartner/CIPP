    },   
    {      
      "route": "/api/EditTenant",
      "allowedRoles": ["deployadmin"]
    },   
    {      
      "route": "/api/DomainAnalyser_OrchestrationStarter",
      "allowedRoles": ["deployadmin"]
    },   
   {
      "route": "/LogoutRedirect",
      "allowedRoles": ["admin", "deployadmin", "editor", "readonly", "authenticated", "anonymous"]
    },
    {
      "route": "/404",
      "allowedRoles": ["admin", "deployadmin", "editor", "readonly", "authenticated", "anonymous"]
    },
    {
      "route": "/api/RemoveStandard",
      "allowedRoles": ["deployadmin"]
    },
    {
      "route": "/api/add*",
      "allowedRoles": ["admin", "deployadmin", "editor"]
    },
    {
      "route": "/api/edit*",
      "allowedRoles": ["admin", "deployadmin", "editor"]
    },
    {
      "route": "/api/ExecSendPush",
      "allowedRoles": ["admin", "deployadmin", "editor", "readonly"]
    },
    {
      "route": "/api/ExecExcludeTenant",
      "allowedRoles": ["deployadmin"]
    },
    {
      "route": "/api/Exec*",
      "allowedRoles": ["admin", "deployadmin", "editor"]
    },
    {
      "route": "/api/Remove*",
      "allowedRoles": ["admin", "deployadmin", "editor"]
    },
    {
      "route": "/cipp/*",
      "allowedRoles": ["admin", "deployadmin"]
    },
    {
      "route": "/tenant/standards/*",
      "allowedRoles": ["admin", "deployadmin"]
    },
    {
      "route": "/",
      "allowedRoles": ["admin", "deployadmin", "editor", "readonly", "reader", "authenticated", "anonymous"]
    },
    {
      "route": "/api/Public*",
      "allowedRoles": ["admin", "deployadmin", "editor", "readonly", "reader", "authenticated", "anonymous"]
    },
    {
      "route": "*",
      "allowedRoles": ["admin", "deployadmin", "editor", "readonly", "reader"]
    }   
  ],
  "navigationFallback": {
    "rewrite": "index.html",
    "exclude": ["/static/*.{png,jpg,gif}", "/css/*"]
  },
  "responseOverrides": {
    "401": {
      "rewrite": "/401"
    },
    "403": {
      "rewrite": "/403"
    },
    "404": {
      "rewrite": "/404"
    }
  },
  "globalHeaders": {
    "content-security-policy": "default-src https: 'unsafe-eval' 'unsafe-inline'; object-src 'none'; img-src 'self' data: *"
  },
  "mimeTypes": {
    ".json": "text/json"
  }
}
